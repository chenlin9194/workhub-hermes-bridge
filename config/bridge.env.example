# WorkHub service address as seen from the Hermes host.
WORKHUB_BASE_URL=http://127.0.0.1:3000

# Generate a strong secret. This must exactly match WorkHub's .env value.
HERMES_WORKHUB_TOKEN=replace-with-a-strong-random-secret

# Windows + WSL Hermes runtime. Change these for the company computer.
HERMES_WSL_DISTRO=Ubuntu-22.04
HERMES_WSL_USER=replace-with-wsl-user

# Keep this at 32 for WorkHub MCP V1.0.
WORKHUB_EXPECTED_TOOL_COUNT=32
